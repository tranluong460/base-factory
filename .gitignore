# ============================================================
# .gitignore cho Node.js Project (2026 - Comprehensive)
# ============================================================

# ======================== LOGS ==============================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ======================== DIAGNOSTIC ========================
# Node.js diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ======================== RUNTIME DATA ======================
pids/
*.pid
*.seed
*.pid.lock

# ======================== DEPENDENCIES ======================
node_modules/
jspm_packages/
web_modules/
bower_components/

# pnpm
.pnpm-store/

# Yarn v3+ (PnP)
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.yarn-integrity

# Bun
bun.lockb

# ======================== BUILD OUTPUT ======================
dist/
build/
out/
.output/
tmp/
temp/

# TypeScript
*.tsbuildinfo
tsconfig.tsbuildinfo

# ======================== TESTING & COVERAGE ================
coverage/
*.lcov
.nyc_output/
lib-cov/

# Playwright
test-results/
playwright-report/
playwright/.cache/

# Jest
jest-coverage/

# Vitest
html/

# ======================== ENVIRONMENT =======================
# dotenv files - NEVER commit secrets
.env
.env.*
!.env.example
!.env.template

# ======================== CACHE =============================
.cache/
.parcel-cache/
.fusebox/
.eslintcache
.stylelintcache
.prettiercache
.turbo/

# Vite
.vite/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ======================== FRAMEWORKS ========================
# Next.js
.next/

# Nuxt.js
.nuxt/

# Gatsby
# public/   # uncomment if using Gatsby (not Next.js)

# SvelteKit
.svelte-kit/

# Remix
.remix/

# Astro
.astro/

# VuePress / VitePress
.vuepress/dist/
.temp/
**/.vitepress/dist/
**/.vitepress/cache/

# Docusaurus
.docusaurus/

# Storybook
storybook-static/

# ======================== SERVERLESS & CLOUD ================
.serverless/
.firebase/
.dynamodb/
.amplify/
.vercel/
.netlify/

# AWS CDK
cdk.out/

# Terraform
*.tfstate
*.tfstate.backup
.terraform/

# ======================== EDITOR & IDE ======================
# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
.vscode-test/

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml

# Vim / Neovim
*.sw?
*.swo
*~
.netrwhist

# Sublime Text
*.sublime-project
*.sublime-workspace

# ======================== OS FILES ==========================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# ======================== PACKAGE OUTPUT ====================
# npm pack
*.tgz

# ======================== MISC ==============================
# Optional npm cache
.npm/

# Optional REPL history
.node_repl_history

# Grunt intermediate storage
.grunt/

# node-waf configuration
.lock-wscript

# Compiled binary addons (N-API / node-gyp)
build/Release/

# TernJS port file
.tern-port

# Docker
docker-compose.override.yml

# Monorepo tools
.nx/cache/
.nx/workspace-data/

# Wrangler (Cloudflare Workers)
.wrangler/
.dev.vars

# AI / LLM tools
.claude/
.cursor/
.aider*
.copilot/

# ======================== PROJECT SPECIFIC ==================
example/
*.local
