branch=$(git rev-parse --abbrev-ref HEAD)

# Allow main directly
if [ "$branch" = "main" ]; then
  exit 0
fi

# All other branches must follow: type/description
pattern="^(feat|fix|chore|docs|refactor|hotfix|release|test|ci|perf|build)\/.+$"

if ! echo "$branch" | grep -qE "$pattern"; then
  echo ""
  echo "ERROR: Invalid branch name!"
  echo ""
  echo "Format:  type/description"
  echo ""
  echo "Types:"
  echo "  feat/xxx     - new feature"
  echo "  fix/xxx      - bug fix"
  echo "  chore/xxx    - maintenance"
  echo "  docs/xxx     - documentation"
  echo "  refactor/xxx - code refactoring"
  echo "  hotfix/xxx   - urgent fix"
  echo "  release/xxx  - release version"
  echo ""
  echo "Examples:"
  echo "  feat/upload-video"
  echo "  fix/sqlite-wal-lock"
  echo "  chore/update-deps"
  echo ""
  echo "Current branch: $branch"
  echo ""
  exit 1
fi
